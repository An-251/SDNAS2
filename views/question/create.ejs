<%- include('../partials/header', { title, active }) %>

<div class="mb-3">
  <h1 class="h3 mb-1">Create new question</h1>
  <p class="text-muted mb-0">Add a question with options and the correct answer index.</p>
</div>

<form method="POST" action="/questions" class="card shadow-sm">
  <div class="card-body">
    <div class="mb-3">
      <label class="form-label" for="text">Question text</label>
      <input class="form-control" id="text" name="text" type="text" required />
    </div>
    <div class="mb-3">
      <label class="form-label" for="options">Options (comma separated)</label>
      <input class="form-control" id="options" name="options" type="text" placeholder="Paris, London, Berlin" required />
    </div>
    <div class="mb-3">
      <label class="form-label" for="keywords">Keywords (comma separated)</label>
      <input class="form-control" id="keywords" name="keywords" type="text" placeholder="capital, geography" />
    </div>
    <div class="mb-3">
      <label class="form-label" for="correctAnswerIndex">Correct answer index (0 = first option)</label>
      <input
        class="form-control"
        id="correctAnswerIndex"
        name="correctAnswerIndex"
        type="number"
        min="0"
        placeholder="0"
        required
      />
      <div class="form-text">Use 0 for the first option, 1 for the second, and so on.</div>
    </div>
    <div class="d-flex gap-2">
      <button class="btn btn-primary" type="submit">Create</button>
      <a class="btn btn-outline-secondary" href="/questions">Cancel</a>
    </div>
  </div>
</form>

<%- include('../partials/footer') %>
