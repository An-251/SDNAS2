<%- include('../partials/header', { title, active }) %>

<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
  <div>
    <h1 class="h3 mb-1">Question details</h1>
    <p class="text-muted mb-0"><%= question.text %></p>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <a class="btn btn-outline-secondary" href="/questions">Back</a>
    <a class="btn btn-outline-primary" href="/questions/<%= question._id %>/try">Try</a>
    <a class="btn btn-outline-warning" href="/questions/<%= question._id %>/edit">Edit</a>
    <form method="POST" action="/questions/<%= question._id %>?_method=DELETE" onsubmit="return confirm('Delete this question?');">
      <input type="hidden" name="_method" value="DELETE" />
      <button class="btn btn-outline-danger" type="submit">Delete</button>
    </form>
  </div>
</div>

<section class="mb-4">
  <h2 class="h5">Options</h2>
  <div class="list-group">
    <% (question.options || []).forEach((option, index) => { %>
      <div class="list-group-item d-flex justify-content-between align-items-center">
        <span><%= option %></span>
        <span class="text-muted">Option <%= index %></span>
      </div>
    <% }) %>
  </div>
</section>

<section class="card shadow-sm">
  <div class="card-body">
    <h3 class="h5">Metadata</h3>
    <% const correctIndex = Number.isInteger(question.correctAnswerIndex) ? question.correctAnswerIndex : -1; %>
    <% const correctText = correctIndex >= 0 && question.options ? question.options[correctIndex] : null; %>
    <div class="row">
      <div class="col-md-6">
        <p class="mb-1 text-muted">Correct answer index</p>
        <p class="fw-semibold"><%= question.correctAnswerIndex %></p>
      </div>
      <div class="col-md-6">
        <p class="mb-1 text-muted">Correct answer</p>
        <p class="fw-semibold"><%= correctText ? `Option ${correctIndex}: ${correctText}` : 'Not set' %></p>
      </div>
      <div class="col-md-6">
        <p class="mb-1 text-muted">Keywords</p>
        <p class="fw-semibold"><%= (question.keywords || []).join(', ') || 'None' %></p>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
