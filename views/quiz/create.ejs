<%- include('../partials/header', { title, active }) %>

<div class="mb-3">
  <h1 class="h3 mb-1">Create new quiz</h1>
  <p class="text-muted mb-0">Start a fresh quiz and add questions later.</p>
</div>

<form method="POST" action="/quizzes" class="card shadow-sm">
  <div class="card-body">
    <div class="mb-3">
      <label class="form-label" for="title">Title</label>
      <input class="form-control" id="title" name="title" type="text" required />
    </div>
    <div class="mb-3">
      <label class="form-label" for="description">Description</label>
      <textarea class="form-control" id="description" name="description" rows="3"></textarea>
    </div>
    <div class="d-flex gap-2">
      <button class="btn btn-primary" type="submit">Create</button>
      <a class="btn btn-outline-secondary" href="/quizzes">Cancel</a>
    </div>
  </div>
</form>

<%- include('../partials/footer') %>
